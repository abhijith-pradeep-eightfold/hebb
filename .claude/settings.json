{
  "env": {
    "CODE_BASE": "/home/ec2-user/vscode",
    "VSCODE_PYTHON": "/home/ec2-user/py3.13-virt/bin/python"
  },
  "permissions": {
    "additionalDirectories": ["/home/ec2-user/vscode"],
    "allow": [
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(tree:*)",
      "Bash(cd:*)",
      "Bash(pwd:*)",
      "Bash(echo:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(cut:*)",
      "Bash(diff:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(realpath:*)",
      "Bash(dirname:*)",
      "Bash(basename:*)",
      "Bash(which:*)",
      "Read(//home/ec2-user/vscode/**)",
      "Write(inputs/**)",
      "Edit(inputs/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/core/tools/bash_exec_policy.py\"",
            "statusMessage": "Checking bash execution policy"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/core/tools/publish.py\" >/dev/null",
            "statusMessage": "Publishing Hebb skills (symlinks + catalog)"
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/core/tools/inject_wiki_index.py\"",
            "statusMessage": "Injecting Hebb wiki index"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/core/tools/log_cadence_check.py\"",
            "statusMessage": "Checking session-log cadence"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "skill-creator@claude-plugins-official": true
  }
}
